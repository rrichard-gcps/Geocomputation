# Micromap of Gwinnett County Public Schools' J. Alvin Wilbanks ISC using Leaflet in R
# You can use the `leaflet` package in R to create an interactive map without needing Mapbox. Below is a code example that generates a micromap of the J. Alvin Wilbanks Instructional Support Center using Leaflet and OpenStreetMap as the tile provider.
# Load required packages
library(leaflet)
# Coordinates for J. Alvin Wilbanks ISC
latitude <- 34.0246
longitude <- -84.0648
# Create a leaflet map
leaflet() %>%
addTiles() %>%  # Add default OpenStreetMap tiles
setView(lng = longitude, lat = latitude, zoom = 16) %>%  # Set view to ISC location
addMarkers(lng = longitude, lat = latitude,
popup = "J. Alvin Wilbanks Instructional Support Center<br>437 Old Peachtree Road, NW<br>Suwanee, Georgia 30024-2978")
# Create a leaflet map
leaflet() %>%
addTiles() %>%  # Add default OpenStreetMap tiles
setView(lng = longitude, lat = latitude, zoom = 17) %>%  # Set view to ISC location
addMarkers(lng = longitude, lat = latitude,
popup = "J. Alvin Wilbanks Instructional Support Center<br>437 Old Peachtree Road, NW<br>Suwanee, Georgia 30024-2978")
