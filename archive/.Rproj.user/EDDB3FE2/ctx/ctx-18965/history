# Create ISC bounding box
bbox <- c(xmin = -84.0800, ymin = 34.0200, xmax = -84.0780, ymax = 34.0215)
isc_bbox <- st_as_sfc(st_bbox(bbox, crs = st_crs(4326)))
# Check if bbox is valid
if (!is.null(isc_bbox) && length(isc_bbox) > 0) {
mapdeck(style = mapdeck_style("satellite")) %>%
add_polygon(
data = isc_bbox,
fill_opacity = 0.5,
stroke_color = "red",
layer_id = "isc_boundary"
)
} else {
stop("ISC bounding box is invalid or empty")
}
