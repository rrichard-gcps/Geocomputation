# Create a leaflet map
leaflet() %>%
addProviderTiles(providers$Esri.WorldImagery) %>%  # Add satellite imagery from Esri
setView(lng = longitude, lat = latitude, zoom = 18) %>%  # Set view to ISC location
addMarkers(lng = longitude, lat = latitude,
popup = "<b>J. Alvin Wilbanks Instructional Support Center</b><br>437 Old Peachtree Road, NW<br>Suwanee, Georgia 30024-2978") %>%
addMiniMap(toggleDisplay = TRUE) %>%  # Add a mini-map for better context
addScaleBar(position = "bottomleft") %>%  # Add a scale bar
addMeasure(primaryLengthUnit = "meters", primaryAreaUnit = "sqmeters")  # Add a measurement tool
# Load required packages
library(leaflet)
library(mapview)
# Coordinates for J. Alvin Wilbanks ISC
latitude <- 34.0159032
longitude <- -84.0557096
# Create a leaflet map with additional features
map <- leaflet() %>%
addProviderTiles(providers$Esri.WorldImagery) %>%  # Add satellite imagery from Esri
setView(lng = longitude, lat = latitude, zoom = 18) %>%  # Set view to ISC location
addMarkers(lng = longitude, lat = latitude,
popup = "<b>J. Alvin Wilbanks Instructional Support Center</b><br>437 Old Peachtree Road, NW<br>Suwanee, Georgia 30024-2978") %>%
addMiniMap(toggleDisplay = TRUE) %>%  # Add a mini-map for better context
addScaleBar(position = "bottomleft") %>%  # Add a scale bar
addMeasure(primaryLengthUnit = "meters", primaryAreaUnit = "sqmeters") %>%  # Add a measurement tool
addCircleMarkers(lng = longitude, lat = latitude, radius = 10, color = "#ff7800", fillOpacity = 0.5, stroke = TRUE)  # Add circle marker for emphasis
# Save map as static image
mapview::mapshot(map, file = "J_Alvin_Wilbanks_ISC_Map.png")
