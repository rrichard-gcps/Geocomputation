# Required libraries
library(sf)          # for handling spatial data
library(raster)      # for handling raster data
library(ggplot2)     # for creating plots
library(elevatr)     # for downloading elevation data
library(dplyr)       # for data wrangling
library(scales)      # for better color scaling
# Load the educational facilities data
sudan_pts <- st_read("day8_hdx/hotosm_sdn_education_facilities_points_shp.shp")
south_sudan_pts <- st_read("day8_hdx/hotosm_ssd_education_facilities_points_shp.shp")
# Combine the two datasets
education_facility_pts <- bind_rows(list(sudan_pts, south_sudan_pts))
# Convert the bounding box to a spatial object for elevation retrieval
bbox <- st_bbox(education_facility_pts)
# Create the coordinates for the bounding box polygon
coords <- matrix(c(bbox["xmin"], bbox["ymin"],
bbox["xmax"], bbox["ymin"],
bbox["xmax"], bbox["ymax"],
bbox["xmin"], bbox["ymax"],
bbox["xmin"], bbox["ymin"]),
ncol = 2, byrow = TRUE)
# Create the polygon and ensure the CRS is applied
bbox_polygon <- st_polygon(list(coords)) %>%
st_sfc(crs = st_crs(education_facility_pts))  # Ensure CRS is set correctly
# Check the CRS to make sure it is correctly assigned
print(st_crs(bbox_polygon))
# Get elevation data for Sudan and South Sudan
# This will now use the corrected bbox_polygon object with a valid CRS
elevation <- get_elev_raster(locations = bbox_polygon, z = 10, clip = "bbox")
# Check the CRS to make sure it is correctly assigned
print(st_crs(bbox_polygon))
# Check the CRS to make sure it is correctly assigned
print(st_crs(bbox_polygon[[1]][[1]]))
